@model DemoMVC.Models.AdopcionViewModel
@{
    ViewData["Title"] = "Registrar Adopción";
}

<div class="container mt-4">

    <h2 class="mb-4">🐾 Nueva Adopción</h2>

    @using (Html.BeginForm("Crear", "Adopcion", FormMethod.Post, new { @class = "card p-4 shadow-sm" }))
    {
        <div class="mb-3">
            @Html.LabelFor(m => m.PersonaId, "Persona", new { @class = "form-label" })
            @Html.DropDownListFor(m => m.PersonaId,
                new SelectList(Model.Personas, "Id", "Nombre"),
                "Seleccione una persona",
                new { @class = "form-select" })
            @Html.ValidationMessageFor(m => m.PersonaId, "", new { @class = "text-danger" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.MascotaId, "Mascota", new { @class = "form-label" })
            @Html.DropDownListFor(m => m.MascotaId,
                new SelectList(Model.MascotasDisponibles, "Id", "Nombre"),
                "Seleccione una mascota",
                new { @class = "form-select" })
            @Html.ValidationMessageFor(m => m.MascotaId, "", new { @class = "text-danger" })
        </div>

        <div class="d-flex justify-content-between">
            @Html.ActionLink("⬅ Volver", "Index", "Adopcion", null, new { @class = "btn btn-outline-secondary" })

            <button type="submit" class="btn btn-success">
                ✔ Confirmar adopción
            </button>
        </div>
    }

</div>
