@{
    ViewData["Title"] = "Listado de Personas (Frontend)";
}

<h2 class="mb-3">Listado de Personas <span class="badge bg-info">Frontend</span></h2>

<a href="/persona-frontend/crear" class="btn btn-success mb-3">Crear Persona</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Cédula</th>
            <th>Nombre</th>
            <th>Edad</th>
            <th></th>
        </tr>
    </thead>
    <tbody id="personas-tbody">
        <tr id="personas-loading">
            <td colspan="4" class="text-center">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                Cargando...
            </td>
        </tr>
    </tbody>
</table>

@section Scripts {
    <script src="~/js/persona-api.js"></script>
    <script src="~/js/persona-index.js"></script>
}
